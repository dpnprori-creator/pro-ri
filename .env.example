# ================================================
# PRO RI DIGITAL COMMAND CENTER
# Environment Variables — VPS Deployment
# ================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ================================================

# ================================================
# SUPABASE — Self-Hosted or Cloud
# ================================================
# Untuk self-hosted Supabase di VPS, gunakan URL internal:
#   http://<vps-ip>:8000
# Untuk Supabase Cloud, gunakan URL dari dashboard:
#   https://<project-id>.supabase.co

# Public URL — bisa dilihat di browser (aman untuk client-side)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Public anon key — aman untuk client-side (dibatasi RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — RAHASIA! Hanya untuk server-side.
# Jangan pernah expose di frontend atau public repo.
SUPABASE_SERVICE_ROLE_KEY=

# ================================================
# APP — Application URLs
# ================================================

# URL publik aplikasi (untuk QR code, verification links, SEO)
# Local:    http://localhost:3000
# Production: https://prori.id
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nama aplikasi (tampil di title bar, metadata, QR code)
NEXT_PUBLIC_APP_NAME=PRO RI Digital Command Center

# Academy LMS — redirect target untuk menu Akademi
NEXT_PUBLIC_ACADEMY_URL=https://academy.prori.id

# ================================================
# DATABASE — Direct PostgreSQL (optional)
# ================================================
# Untuk self-hosted Supabase, koneksi langsung ke Postgres
# Berguna untuk menjalankan consolidated-migration.sql via CLI:
#   psql "$DATABASE_URL" -f supabase/consolidated-migration.sql
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ================================================
# DEPLOYMENT — VPS / Node.js
# ================================================
# Port untuk Next.js production server (default: 3000)
# PORT=3000
# Node environment
# NODE_ENV=production

# ================================================
# STORAGE — File Upload (Opsional)
# ================================================
# Secara default, file upload menggunakan Supabase Storage.
# Cloudflare R2 (S3-compatible) adalah alternatif opsional.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_DOMAIN=

# ================================================
# EXAMPLE VALUES (untuk self-hosted Supabase)
# ================================================
# Setelah setup Supabase di VPS, nilai default-nya:
#
#   NEXT_PUBLIC_SUPABASE_URL=http://<vps-ip>:8000
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-dari-kong>
#   SUPABASE_SERVICE_ROLE_KEY=<service-role-key-dari-kong>
#   NEXT_PUBLIC_APP_URL=http://<vps-ip>:3000
#
# Cara mendapatkan keys dari self-hosted Supabase:
#   sudo docker exec -it supabase-kong cat /etc/kong/kong.yml
